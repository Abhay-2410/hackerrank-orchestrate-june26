# Copy to .env in repo root and fill in at least one provider key.
# Provider priority: ANTHROPIC_API_KEY > OLLAMA_API_KEY > GEMINI_API_KEY

# Recommended for final submission (best accuracy)
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# Free fallback — Ollama cloud
OLLAMA_API_KEY=your-ollama-key-here
OLLAMA_MODEL=gemma4:31b
OLLAMA_HOST=https://ollama.com

# Alternative free tier
GEMINI_API_KEY=your-gemini-key-here
